# ============================================================
# CONTINENTAL PROJECT — AGENT 2 — Environment Variables
# ============================================================

# ── LLM Keys ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Google Auth (same credentials as Agent 1) ───────────────
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["..."]}}
GOOGLE_TOKEN_JSON={"refresh_token":"1//0g..."}

# ── Google Drive ─────────────────────────────────────────────
# Must match the folder name used in Agent 1
GD_PARENT_FOLDER_NAME=Continental

# BILLS_SHEET_ID is optional — Agent 2 auto-discovers the Bills
# spreadsheet from Google Drive. Only set this if auto-discovery fails.
# BILLS_SHEET_ID=your_sheet_id_here

# ── Server ───────────────────────────────────────────────────
PORT=3001
